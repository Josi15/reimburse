# =========================================================================
# STAGING environment template — copy to `.env` on the staging server.
# Sesuai strategi Phase 3: storage S3, queue database, mail SMTP nyata.
# JANGAN commit file .env yang sudah terisi kredensial.
# =========================================================================

APP_NAME="Reimbursement Management System"
APP_ENV=staging
APP_KEY=
APP_DEBUG=true
APP_URL=https://staging.rms.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ---- Database (PostgreSQL) ----------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=reimbursement_staging
DB_USERNAME=rms_user
DB_PASSWORD=

# ---- Session / Cache / Queue --------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---- Filesystem: S3-compatible ------------------------------------------
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=rms-staging-attachments
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- Mail: SMTP nyata (mis. Mailtrap staging) ---------------------------
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@staging.rms.example"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
