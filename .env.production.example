# =========================================================================
# PRODUCTION environment template — copy to `.env` on the production server.
# Sesuai strategi Phase 3: APP_DEBUG=false, storage S3, queue+cache Redis,
# mail SMTP korporat. Kredensial WAJIB via secret manager, bukan repo.
# =========================================================================

APP_NAME="Reimbursement Management System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://rms.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# ---- Database (PostgreSQL) ----------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=reimbursement
DB_USERNAME=
DB_PASSWORD=

# ---- Session / Cache / Queue (Redis untuk throughput) -------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# ---- Filesystem: S3-compatible ------------------------------------------
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=rms-attachments
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- Mail: SMTP korporat / SES / Postmark -------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@rms.example"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
